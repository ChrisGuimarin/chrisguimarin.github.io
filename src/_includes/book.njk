---
layout: base.njk
---

<article class="book">
    <div class="book-header">
        <img src="{{ cover }}" alt="{{ title }} book cover" class="book-cover" loading="eager" decoding="async">
        <div class="book-meta">
            <h1>{{ title }}</h1>
            <p class="book-author">by {{ author }}</p>
            <p class="book-category">{{ category }}</p>
            <a href="{{ link }}" class="book-link">Find this book</a>
        </div>
    </div>

    {{ content | safe }}
</article>

<a href="/shelf/" class="shelf-browse-link">Browse the Shelf →</a>